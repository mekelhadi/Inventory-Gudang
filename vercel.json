{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "builds": [
        {
            "src": "/api/index.php",
            "use": "vercel-php@0.9.0"
        },
        {
            "src": "/public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/assets/(.*)",
            "dest": "/public/assets/$1"
        },
        {
            "src": "/build/assets/(.*)",
            "dest": "/public/build/assets/$1"
        },
        {
            "src": "/favicon.(.*)",
            "dest": "/public/favicon.$1"
        },
        {
            "src": "/robots.txt",
            "dest": "/public/robots.txt"
        },
        {
            "src": "/storage/(.*)",
            "dest": "/public/storage/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_NAME": "Inventaris-Gudang",
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "APP_URL": "https://inventory-gudang-phi.vercel.app",
        "DB_CONNECTION": "mysql",
        "DB_HOST": "gateway01.ap-southeast-1.prod.aws.tidbcloud.com",
        "DB_PORT": "4000",
        "DB_DATABASE": "inventaris_gudang",
        "DB_USERNAME": "36aZfvaVsepeZ58.root",
        "DB_PASSWORD": "mvg2PuaPQ7XvxQ1L",
        "DB_UNIX_SOCKET": "",
        "APP_CONFIG_CACHE": "/tmp/config.php",
        "APP_EVENTS_CACHE": "/tmp/events.php",
        "APP_PACKAGES_CACHE": "/tmp/packages.php",
        "APP_ROUTES_CACHE": "/tmp/routes.php",
        "APP_SERVICES_CACHE": "/tmp/services.php",
        "CACHE_DRIVER": "array",
        "CACHE_STORE": "array",
        "LOG_CHANNEL": "stderr",
        "SESSION_DRIVER": "cookie",
        "VIEW_COMPILED_PATH": "/tmp"
    }
}
